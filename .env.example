# Copy this file to .env and fill in real values. .env is gitignored;
# NEVER put real secrets in this template.

# --- Postgres / Supabase ---
# Local Postgres:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gocrm?sslmode=disable
# Supabase (Project Settings -> Database -> Connection string -> URI). TLS is required.
# URL-encode special chars in the password (e.g. '@' -> '%40'). Direct host (db.<ref>...:5432)
# is IPv6-only and best for migrations; use the pooler host on IPv4-only networks.
# DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ISSUER=go-crm
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# --- SSO / OIDC ---
# The SPA origin the SSO callback redirects back to (token delivered in URL fragment).
WEB_APP_URL=http://localhost:4321
# Public base URL of the SSO routes; the provider callback is "<base>/<provider>/callback".
# Register that callback URL in each provider's console, e.g.
#   http://localhost:8080/api/v1/auth/sso/google/callback
OIDC_REDIRECT_BASE=http://localhost:8080/api/v1/auth/sso
# A provider is enabled only when its CLIENT_ID is set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- NATS / JetStream ---
NATS_URL=nats://localhost:4222

# --- Gateway ---
GATEWAY_ADDR=:8080

# --- Web (Astro) ---
PUBLIC_API_URL=http://localhost:8080
